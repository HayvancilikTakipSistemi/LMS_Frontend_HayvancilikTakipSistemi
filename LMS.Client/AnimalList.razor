@page "/animals"
@inject LMS.Client.Services.IAnimalService AnimalService
@using LMS.Shared.Models

<h3>Ahırdaki Hayvanlar</h3>

<input @bind="aramaKelimesi" @bind:event="oninput" placeholder="Küpe numarası yaz..." class="form-control mb-3" />
<a href="/animal/add" class="btn btn-success mb-3">Yeni Hayvan Ekle</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Küpe No</th>
            <th>Cinsiyet</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var hayvan in SuzulmusListe)
        {
            <tr>
                <td>@hayvan.KupeNo</td>
                <td>@hayvan.Cinsiyet</td>
                <td>
                    <a href="/animal/detail/@hayvan.HayvanID" class="btn btn-info btn-sm">Detay</a> 
                    <a href="/animal/edit/@hayvan.HayvanID" class="btn btn-warning btn-sm">Düzenle</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Hayvan> tumHayvanlar = new();
    private string aramaKelimesi = "";

    protected override async Task OnInitializedAsync()
    {
        tumHayvanlar = await AnimalService.GetHayvanlarAsync();
    }

    private List<Hayvan> SuzulmusListe => tumHayvanlar
        .Where(h => string.IsNullOrEmpty(aramaKelimesi) || h.KupeNo.Contains(aramaKelimesi))
        .ToList();
}