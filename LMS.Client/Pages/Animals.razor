@page "/animals"
@attribute [Authorize]

<div class="space-y-8">
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <h2 class="text-4xl font-headline font-extrabold text-white tracking-tight">Hayvan Rehberi</h2>
            <p class="text-on-surface-variant max-w-xl">Çiftlikteki tüm canlı varlıkların dijital envanteri. Sağlık durumlarını, biyometrik verileri ve yaşam döngüsünü buradan yönetin.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="flex -space-x-3 overflow-hidden">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDOIahpTAuyIRXhdwPOFf2azQyn7oPTRbmDTyd5cUTWeurJ5qJQ37VmKtJmmYH-FhmgTrlq6Wh3SnQLhkwNaZzrGpEJ_4McmB9PjO9Tmk6GXRNfSbLnRNbOokHfO5o9ATSpB9xDpBA8iX1VeOFF6TlTo5USzXAcfX8TcqM5gKTnXYCpmn8X6XFY4HIldJCT_JeIEBWbkYNlphGM0YW_AryJnffN1a2ANck52TrOUgNM2pTAuYygsKoawcveajsVnlkEDIJZvUnGU7k" class="inline-block h-10 w-10 rounded-full ring-2 ring-surface" />
                <div class="flex items-center justify-center h-10 w-10 rounded-full ring-2 ring-surface bg-surface-container-highest text-[10px] font-bold text-primary">+@(animals?.Count ?? 0)</div>
            </div>
        </div>
    </div>

    <!-- Action Bar -->
    <div class="flex flex-col lg:flex-row gap-4 mb-8">
        <div class="flex-1 flex flex-wrap items-center gap-3">
            <div class="flex items-center bg-surface-container rounded-xl px-4 py-2 ghost-border focus-within:border-primary/50 transition-all">
                <span class="text-xs font-bold text-on-surface-variant mr-3 border-r border-white/10 pr-3">DURUM</span>
                <select class="bg-transparent border-none text-sm text-white focus:ring-0 cursor-pointer">
                    <option>Tümü</option>
                    <option>Sağlıklı</option>
                    <option>Gözlem Altında</option>
                    <option>Hasta</option>
                </select>
            </div>
            <div class="flex items-center bg-surface-container rounded-xl px-4 py-2 ghost-border focus-within:border-primary/50 transition-all">
                <span class="text-xs font-bold text-on-surface-variant mr-3 border-r border-white/10 pr-3">CİNSİYET</span>
                <select class="bg-transparent border-none text-sm text-white focus:ring-0 cursor-pointer">
                    <option>Tümü</option>
                    <option>Erkek</option>
                    <option>Dişi</option>
                </select>
            </div>
            <button class="p-2.5 rounded-xl bg-surface-container-highest text-white hover:bg-white/10 transition-all">
                <span class="material-symbols-outlined text-xl">filter_list</span>
            </button>
        </div>
        <button @onclick="OpenModal" class="bg-primary-container text-on-primary-container font-bold px-6 py-3 rounded-xl flex items-center justify-center gap-2 hover:shadow-[0_0_30px_rgba(107,254,156,0.2)] transition-all duration-300 ease-out-expo hover:-translate-y-0.5 active:translate-y-0">
            <span class="material-symbols-outlined font-bold">add_circle</span>
            Yeni Hayvan Ekle
        </button>
    </div>

    <!-- Table Section -->
    <div class="bg-surface-container rounded-xl overflow-hidden ghost-border">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-highest/50">
                    <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-widest">Küpe No</th>
                    <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-widest">Cinsiyet</th>
                    <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-widest">Doğum Tarihi</th>
                    <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-widest">Durum</th>
                    <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-widest text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @if (animals == null)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-on-surface-variant">Yükleniyor...</td>
                    </tr>
                }
                else if (!animals.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-on-surface-variant">Kayıtlı hayvan bulunamadı.</td>
                    </tr>
                }
                else
                {
                    foreach (var animal in animals)
                    {
                        <tr class="group hover:bg-white/5 transition-all duration-300">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="@(animal.HayvanDurumID == 1 ? "w-2 h-2 rounded-full bg-primary animate-pulse" : (animal.HayvanDurumID == 2 ? "w-2 h-2 rounded-full bg-tertiary" : "w-2 h-2 rounded-full bg-error"))"></div>
                                    <span class="font-headline font-bold text-white tracking-wider">@animal.KupeNo</span>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <span class="flex items-center gap-2 text-sm text-on-surface-variant">
                                    <span class="material-symbols-outlined @(animal.Cinsiyet == "D" ? "text-tertiary" : "text-primary") text-sm">@(animal.Cinsiyet == "D" ? "female" : "male")</span>
                                    @(animal.Cinsiyet == "D" ? "Dişi" : "Erkek")
                                </span>
                            </td>
                            <td class="px-6 py-5 text-sm text-on-surface-variant font-medium">@(animal.DogumTarihi?.ToString("dd MMM yyyy") ?? "Belirtilmedi")</td>
                            <td class="px-6 py-5">
                                @if (animal.HayvanDurumID == 1)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-wider border border-primary/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Sağlıklı
                                    </span>
                                }
                                else if (animal.HayvanDurumID == 2)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-tertiary/10 text-tertiary text-[10px] font-bold uppercase tracking-wider border border-tertiary/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span> Hasta
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-error/10 text-error text-[10px] font-bold uppercase tracking-wider border border-error/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-error"></span> Kritik
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center justify-end gap-2">
                                    <button @onclick="() => NavigateToAnalysis(animal.HayvanID)" class="p-2 text-on-surface-variant hover:text-primary hover:bg-primary/5 rounded-lg transition-all" title="AI Analiz">
                                        <span class="material-symbols-outlined text-xl">psychology</span>
                                    </button>
                                    <button @onclick="() => DeleteAnimal(animal.HayvanID)" class="p-2 text-on-surface-variant hover:text-error hover:bg-error/5 rounded-lg transition-all" title="Sil">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Overlay Backdrop -->
@if(isModalOpen)
{
<div class="fixed inset-0 z-[60] bg-black/60 backdrop-blur-xl flex items-center justify-center p-4">
    <!-- Modal Container -->
    <div class="glass-panel w-full max-w-2xl rounded-3xl shadow-[0_0_80px_rgba(107,254,156,0.15)] flex flex-col overflow-hidden ease-out-expo duration-500">
        <!-- Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-outline-variant/10">
            <div>
                <h3 class="text-2xl font-headline font-bold text-white">Yeni Hayvan Ekle</h3>
                <p class="text-on-surface-variant text-sm mt-1">Dijital envantere yeni bir kayıt oluşturun.</p>
            </div>
            <button @onclick="CloseModal" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-highest hover:bg-surface-bright transition-colors group">
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-white">close</span>
            </button>
        </div>

        <!-- Form Content -->
        <!-- Form Content -->
        <EditForm Model="newAnimal" OnValidSubmit="HandleAddAnimal" class="p-8 space-y-8">
            <DataAnnotationsValidator />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Ear Tag Number -->
                <div class="space-y-2">
                    <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest px-1">Küpe No</label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors">tag</span>
                        <InputText @bind-Value="newAnimal.KupeNo" placeholder="TR00000000" class="w-full bg-surface-container-lowest border-none ring-1 ring-outline-variant/30 rounded-xl py-3.5 pl-12 pr-4 text-white placeholder:text-neutral-600 focus:ring-2 focus:ring-primary/50 transition-all outline-none" />
                    </div>
                </div>

                <!-- Gender Selection -->
                <div class="space-y-2">
                    <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest px-1">Cinsiyet</label>
                    <div class="grid grid-cols-2 gap-2 bg-surface-container-lowest p-1.5 rounded-xl ring-1 ring-outline-variant/30">
                        <button type="button" @onclick='() => newAnimal.Cinsiyet = "E"' class="flex items-center justify-center gap-2 py-2 rounded-lg @(newAnimal.Cinsiyet == "E" ? "bg-primary/10 text-primary font-semibold ring-1 ring-primary/30" : "text-on-surface-variant hover:bg-surface-variant transition-all font-medium")">
                            <span class="material-symbols-outlined text-sm">male</span> Erkek
                        </button>
                        <button type="button" @onclick='() => newAnimal.Cinsiyet = "D"' class="flex items-center justify-center gap-2 py-2 rounded-lg @(newAnimal.Cinsiyet == "D" ? "bg-primary/10 text-primary font-semibold ring-1 ring-primary/30" : "text-on-surface-variant hover:bg-surface-variant transition-all font-medium")">
                            <span class="material-symbols-outlined text-sm">female</span> Dişi
                        </button>
                    </div>
                </div>
            </div>

            <!-- Initial Status -->
            <div class="space-y-2">
                <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest px-1">Başlangıç Durumu</label>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <button type="button" class="flex items-center gap-3 p-4 rounded-2xl bg-surface-container-lowest ring-2 ring-primary/20 transition-all text-left">
                        <div class="w-3 h-3 rounded-full bg-primary animate-pulse"></div>
                        <div>
                            <p class="text-sm font-bold text-white">Sağlıklı</p>
                            <p class="text-[10px] text-on-surface-variant">Genel durumu mükemmel</p>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Footer Actions -->
            <div class="flex flex-col md:flex-row gap-4 pt-4 border-t border-outline-variant/10">
                <button type="submit" class="flex-1 py-4 px-6 rounded-2xl bg-primary-container text-on-primary-container font-headline font-bold text-lg hover:shadow-[0_0_25px_rgba(107,254,156,0.3)] hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-3">
                    Hayvanı Kaydet
                </button>
                <button @onclick="CloseModal" type="button" class="px-10 py-4 rounded-2xl font-headline font-semibold text-on-surface-variant hover:text-white hover:bg-white/5 transition-all">
                    İptal
                </button>
            </div>
        </EditForm>
    </div>
</div>
}

@code {
    [Inject] public IAnimalService AnimalService { get; set; } = default!;
    [Inject] public NavigationManager Navigation { get; set; } = default!;

    private List<Hayvan>? animals;
    private Hayvan newAnimal = new() { Cinsiyet = "D", HayvanDurumID = 1, DogumTarihi = DateTime.UtcNow };

    private bool isModalOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAnimals();
    }

    private async Task LoadAnimals()
    {
        animals = await AnimalService.GetAnimalsAsync();
    }

    private void OpenModal()
    {
        newAnimal = new() { Cinsiyet = "D", HayvanDurumID = 1, DogumTarihi = DateTime.UtcNow };
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task HandleAddAnimal()
    {
        var result = await AnimalService.AddAnimalAsync(newAnimal);
        if (result != null)
        {
            CloseModal();
            await LoadAnimals();
        }
    }

    private async Task DeleteAnimal(int id)
    {
        var success = await AnimalService.DeleteAnimalAsync(id);
        if (success)
        {
            await LoadAnimals();
        }
    }

    private void NavigateToAnalysis(int id)
    {
        Navigation.NavigateTo($"/animal-analysis/{id}");
    }
}
