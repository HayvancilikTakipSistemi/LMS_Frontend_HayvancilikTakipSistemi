@page "/"
@using LMS.Shared.DTOs
@attribute [Authorize]

<div class="space-y-8">
    <!-- Hero Heading -->
    <section>
        <h2 class="text-4xl font-extrabold font-headline text-white tracking-tight">Genel Bakış</h2>
        <p class="text-zinc-500 mt-1">Hoş geldiniz, çiftliğinizdeki güncel durum ve AI analizleri aşağıdadır.</p>
    </section>

    @if (animals == null)
    {
        <div class="glass-card p-12 rounded-2xl flex flex-col items-center justify-center text-center">
            <span class="material-symbols-outlined animate-spin text-primary text-4xl mb-4">hourglass_empty</span>
            <p class="text-on-surface-variant">Sistem analizleri derleniyor...</p>
        </div>
    }
    else
    {
    <!-- Top Row: Premium Glassmorphic Cards -->
    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Animals -->
        <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-zinc-400 text-sm font-medium mb-1">Toplam Hayvan</p>
                    <h3 class="text-3xl font-bold text-white font-headline">@(animals?.Count ?? 0)</h3>
                </div>
                <div class="bg-primary/10 p-3 rounded-xl text-primary">
                    <span class="material-symbols-outlined" data-icon="pets">pets</span>
                </div>
            </div>
            <div class="mt-4 flex items-center space-x-2">
                <span class="flex items-center text-xs font-semibold text-primary bg-primary/10 px-2 py-1 rounded-full">
                    <span class="material-symbols-outlined text-xs mr-1" data-icon="trending_up">trending_up</span>
                    +5%
                </span>
                <span class="text-[10px] text-zinc-500 uppercase tracking-wider">Geçen Aya Göre</span>
            </div>
        </div>

        <!-- High Warning Risks -->
        <div class="glass-card p-6 rounded-2xl relative overflow-hidden">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-zinc-400 text-sm font-medium mb-1">Yüksek Riskli Uyarılar</p>
                    <h3 class="text-3xl font-bold text-white font-headline">@GetCriticalCount()</h3>
                </div>
                <div class="bg-error/10 p-3 rounded-xl text-error">
                    <span class="material-symbols-outlined" data-icon="warning">warning</span>
                </div>
            </div>
            <div class="mt-4 flex items-center space-x-2">
                <span class="flex items-center text-xs font-semibold text-error bg-error/10 px-2 py-1 rounded-full">
                    <span class="material-symbols-outlined text-xs mr-1" data-icon="trending_down">trending_down</span>
                    -2%
                </span>
                <span class="text-[10px] text-zinc-500 uppercase tracking-wider">Kritik Durum</span>
            </div>
        </div>

        <!-- Total Farmers -->
        <div class="glass-card p-6 rounded-2xl relative overflow-hidden">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-zinc-400 text-sm font-medium mb-1">Toplam Çiftçi</p>
                    <h3 class="text-3xl font-bold text-white font-headline">1</h3>
                </div>
                <div class="bg-tertiary/10 p-3 rounded-xl text-tertiary">
                    <span class="material-symbols-outlined" data-icon="groups">groups</span>
                </div>
            </div>
            <div class="mt-4 flex items-center space-x-2">
                <span class="flex items-center text-xs font-semibold text-zinc-400 bg-zinc-800 px-2 py-1 rounded-full">
                    <span class="material-symbols-outlined text-xs mr-1" data-icon="stable">remove</span>
                    Stabil
                </span>
                <span class="text-[10px] text-zinc-500 uppercase tracking-wider">Aktif Personel</span>
            </div>
        </div>

        <!-- Healthy Rate -->
        <div class="glass-card p-6 rounded-2xl relative overflow-hidden border-l-4 border-emerald-400">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-zinc-400 text-sm font-medium mb-1">Sağlık Oranı</p>
                    <h3 class="text-3xl font-bold text-white font-headline">%@Math.Round(GetPercentage(GetHealthyCount()))</h3>
                </div>
                <div class="bg-primary/10 p-3 rounded-xl text-primary">
                    <span class="material-symbols-outlined" data-icon="health_and_safety">health_and_safety</span>
                </div>
            </div>
            <div class="mt-4 flex items-center space-x-2">
                <span class="flex items-center text-xs font-semibold text-primary bg-primary/10 px-2 py-1 rounded-full">
                    <span class="material-symbols-outlined text-xs mr-1" data-icon="trending_up">trending_up</span>
                    +1%
                </span>
                <span class="text-[10px] text-zinc-500 uppercase tracking-wider">Genel Sürü</span>
            </div>
        </div>
    </section>

    <!-- Middle Row: Charts with Bento Layout -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Animal Health Over Time -->
        <div class="lg:col-span-2 glass-card p-8 rounded-2xl">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h3 class="text-xl font-bold text-white font-headline">Zaman İçinde Hayvan Sağlığı</h3>
                    <p class="text-sm text-zinc-500">Son 30 günlük gelişim analizi</p>
                </div>
                <select class="bg-surface-container border-none text-xs rounded-lg text-zinc-300 focus:ring-1 focus:ring-primary/20">
                    <option>Son 30 Gün</option>
                    <option>Son 6 Ay</option>
                </select>
            </div>
            <!-- Chart Placeholder Visual -->
            <div class="h-64 flex items-end justify-between space-x-2 pb-2">
                <div class="flex-1 bg-primary/20 rounded-t-lg h-[40%] hover:bg-primary/40 transition-colors relative group">
                    <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-surface text-[10px] px-2 py-1 rounded hidden group-hover:block border border-white/10">72%</div>
                </div>
                <div class="flex-1 bg-primary/20 rounded-t-lg h-[55%] hover:bg-primary/40 transition-colors"></div>
                <div class="flex-1 bg-primary/30 rounded-t-lg h-[45%] hover:bg-primary/40 transition-colors"></div>
                <div class="flex-1 bg-primary/40 rounded-t-lg h-[70%] hover:bg-primary/40 transition-colors"></div>
                <div class="flex-1 bg-primary/20 rounded-t-lg h-[60%] hover:bg-primary/40 transition-colors"></div>
                <div class="flex-1 bg-primary/50 rounded-t-lg h-[85%] hover:bg-primary/40 transition-colors"></div>
                <div class="flex-1 bg-primary/60 rounded-t-lg h-[94%] hover:bg-primary/40 transition-colors"></div>
            </div>
            <div class="flex justify-between mt-4 text-[10px] text-zinc-500 uppercase font-semibold tracking-widest">
                <span>Pzt</span><span>Sal</span><span>Çar</span><span>Per</span><span>Cum</span><span>Cmt</span><span>Paz</span>
            </div>
        </div>

        <!-- Status Breakdown -->
        <div class="glass-card p-8 rounded-2xl flex flex-col">
            <h3 class="text-xl font-bold text-white font-headline mb-2">Durum Dağılımı</h3>
            <p class="text-sm text-zinc-500 mb-8">Güncel sağlık segmentasyonu</p>
            <div class="flex-1 flex flex-col justify-center items-center relative py-6">
                <!-- Custom SVG Donut -->
                <svg class="w-48 h-48 transform -rotate-90">
                    <circle class="text-zinc-800" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-width="12"></circle>
                    <circle class="text-primary transition-all duration-1000" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-dasharray="502" stroke-dashoffset="@GetDashOffsetPrimary()" stroke-width="12"></circle>
                    <circle class="text-tertiary transition-all duration-1000" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-dasharray="502" stroke-dashoffset="@GetDashOffsetTertiary()" stroke-width="12"></circle>
                    <circle class="text-error transition-all duration-1000" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-dasharray="502" stroke-dashoffset="@GetDashOffsetError()" stroke-width="12"></circle>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span class="text-3xl font-bold text-white">@(animals?.Count ?? 0)</span>
                    <span class="text-[10px] text-zinc-500 uppercase tracking-widest">Toplam</span>
                </div>
            </div>
            <div class="space-y-3 mt-6">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full bg-primary"></div>
                        <span class="text-sm text-zinc-300">Sağlıklı</span>
                    </div>
                    <span class="text-sm font-bold text-white">%@Math.Round(GetPercentage(GetHealthyCount()))</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full bg-tertiary"></div>
                        <span class="text-sm text-zinc-300">Gözlem Altında</span>
                    </div>
                    <span class="text-sm font-bold text-white">%@Math.Round(GetPercentage(GetObservationCount()))</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full bg-error"></div>
                        <span class="text-sm text-zinc-300">Kritik</span>
                    </div>
                    <span class="text-sm font-bold text-white">%@Math.Round(GetPercentage(GetCriticalCount()))</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Bottom Row: Recent Alerts -->
    <section class="glass-card rounded-2xl overflow-hidden mb-12">
        <div class="px-8 py-6 border-b border-white/5 flex justify-between items-center">
            <div>
                <h3 class="text-xl font-bold text-white font-headline">Son Uyarılar</h3>
                <p class="text-sm text-zinc-500">AI destekli anlık sağlık ve hareket bildirimleri</p>
            </div>
            <button class="text-sm font-semibold text-emerald-400 hover:text-emerald-300 transition-colors">Tümünü Gör</button>
        </div>
        <div class="divide-y divide-white/5">
            <!-- Alert 1 -->
            <div class="px-8 py-4 flex items-center hover:bg-white/[0.02] transition-colors group">
                <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center text-error mr-4">
                    <span class="material-symbols-outlined" data-icon="monitor_heart">monitor_heart</span>
                </div>
                <div class="flex-1">
                    <h4 class="text-sm font-bold text-white group-hover:text-primary transition-colors">Hayvan #402: Düşük Hareketlilik</h4>
                    <p class="text-xs text-zinc-500">Sektör B-12 | Hareket oranı normalin %40 altında.</p>
                </div>
                <div class="text-right flex flex-col items-end space-y-2">
                    <span class="text-[10px] text-zinc-600 font-medium">2 Dakika Önce</span>
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-error/10 text-error border border-error/20">Acil</span>
                </div>
            </div>
            <!-- Alert 2 -->
            <div class="px-8 py-4 flex items-center hover:bg-white/[0.02] transition-colors group">
                <div class="w-12 h-12 rounded-xl bg-tertiary/10 flex items-center justify-center text-tertiary mr-4">
                    <span class="material-symbols-outlined" data-icon="thermostat">thermostat</span>
                </div>
                <div class="flex-1">
                    <h4 class="text-sm font-bold text-white group-hover:text-primary transition-colors">Hayvan #12: Sıcaklık Artışı</h4>
                    <p class="text-xs text-zinc-500">Karantina Bölgesi | Vücut sıcaklığı 40.2°C olarak tespit edildi.</p>
                </div>
                <div class="text-right flex flex-col items-end space-y-2">
                    <span class="text-[10px] text-zinc-600 font-medium">15 Dakika Önce</span>
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-tertiary/10 text-tertiary border border-tertiary/20">Gözlem</span>
                </div>
            </div>
            <!-- Alert 3 -->
            <div class="px-8 py-4 flex items-center hover:bg-white/[0.02] transition-colors group">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mr-4">
                    <span class="material-symbols-outlined" data-icon="task_alt">task_alt</span>
                </div>
                <div class="flex-1">
                    <h4 class="text-sm font-bold text-white group-hover:text-primary transition-colors">Hayvan #288: Doğum Tamamlandı</h4>
                    <p class="text-xs text-zinc-500">Doğumhane A | Anne ve buzağı durumu sağlıklı.</p>
                </div>
                <div class="text-right flex flex-col items-end space-y-2">
                    <span class="text-[10px] text-zinc-600 font-medium">1 Saat Önce</span>
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20">Tamamlandı</span>
                </div>
            </div>
        </div>
    </section>
    }
</div>

@code {
    [Inject] public IAnimalService AnimalService { get; set; } = default!;

    private List<AnimalDto>? animals;

    protected override async Task OnInitializedAsync()
    {
        animals = await AnimalService.GetAnimalsAsync();
    }

    private int GetHealthyCount()
    {
        return animals?.Count(x => x.AnimalStatusID == 1) ?? 0;
    }

    private int GetObservationCount()
    {
        return animals?.Count(x => x.AnimalStatusID == 2) ?? 0;
    }

    private int GetCriticalCount()
    {
        return animals?.Count(x => x.AnimalStatusID > 2) ?? 0; // everything else is critical (3, 4, 5)
    }

    private decimal GetPercentage(int count)
    {
        if (animals == null || animals.Count == 0) return 0;
        return ((decimal)count / animals.Count) * 100;
    }

    // SVG Offset Calculations for Donut
    // Full circle is 502. 
    // Format: background (primary) is full. 
    // Tertiary is layered on top, dashed based on observation + critical
    // Error is layered on top, dashed based on critical only.

    private string GetDashOffsetPrimary()
    {
        return "0"; // Healthy covers the whole circle (or baseline)
    }

    private string GetDashOffsetTertiary()
    {
        if (animals == null || animals.Count == 0) return "502";
        // observation + critical
        var combined = GetObservationCount() + GetCriticalCount();
        var perc = GetPercentage(combined) / 100;
        var offset = 502 - (502 * perc);
        return offset.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
    }

    private string GetDashOffsetError()
    {
        if (animals == null || animals.Count == 0) return "502";
        var perc = GetPercentage(GetCriticalCount()) / 100;
        var offset = 502 - (502 * perc);
        return offset.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
    }
}
