@page "/auth"
@layout EmptyLayout

<main class="relative z-10 w-full max-w-md px-6">
    <div class="glass-panel p-8 md:p-10 rounded-xl shadow-2xl flex flex-col gap-8">
        <!-- Editorial Header -->
        <div class="space-y-2">
            <h1 class="font-headline text-3xl font-bold tracking-tight text-white">Sistem Erişimi</h1>
            <p class="text-on-surface-variant text-sm leading-relaxed">Biyolojik varlıkların ve hayvancılık verilerinin modern küratörü için güvenli portal.</p>
        </div>

        <!-- Toggle/Switcher -->
        <div class="relative flex p-1 bg-surface-container-lowest rounded-md">
            <input type="radio" id="login" name="auth-mode" class="hidden peer/login" checked="@isLogin" @onchange="() => SetMode(true)" />
            <input type="radio" id="register" name="auth-mode" class="hidden peer/register" checked="@(!isLogin)" @onchange="() => SetMode(false)" />
            
            <label for="login" class="relative z-10 flex-1 py-2 text-center text-sm font-medium cursor-pointer transition-colors duration-300 peer-checked/login:text-on-primary-container text-white/40">
                Giriş Yap
            </label>
            <label for="register" class="relative z-10 flex-1 py-2 text-center text-sm font-medium cursor-pointer transition-colors duration-300 peer-checked/register:text-on-primary-container text-white/40">
                Kayıt Ol
            </label>
            
            <!-- Animated Indicator -->
            <div class="absolute top-1 left-1 h-[calc(100%-8px)] w-[calc(50%-4px)] bg-primary rounded-md transition-transform duration-500 ease-out-expo @(isLogin ? "" : "translate-x-full")"></div>
        </div>

        <!-- Form Content -->
        <EditForm Model="currentModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-3 mb-4 rounded-md bg-error/10 border border-error/20 text-error text-xs font-bold text-center">
                    @errorMessage
                </div>
            }

            <div class="flex flex-col gap-6">
                <!-- Kimlik Field -->
                <div class="space-y-1.5">
                    <label class="text-[10px] uppercase tracking-widest font-bold text-primary px-1">KİMLİK</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-sm">person</span>
                        <InputText @bind-Value="loginModel.Username" placeholder="Kullanıcı Adı" class="w-full bg-surface-container-lowest border-none rounded-md py-3.5 pl-11 pr-4 text-sm text-white placeholder:text-white/20 focus:ring-1 focus:ring-primary focus:bg-surface-container transition-all ease-out-expo" />
                    </div>
                </div>
                
                <!-- Güvenlik Field -->
                <div class="space-y-1.5">
                    <label class="text-[10px] uppercase tracking-widest font-bold text-primary px-1">GÜVENLİK</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-sm">lock</span>
                        <InputText @bind-Value="loginModel.Password" type="password" placeholder="••••••••" class="w-full bg-surface-container-lowest border-none rounded-md py-3.5 pl-11 pr-4 text-sm text-white placeholder:text-white/20 focus:ring-1 focus:ring-primary focus:bg-surface-container transition-all ease-out-expo" />
                    </div>
                </div>

                <!-- Registration Protocol Role -->
                <div class="space-y-1.5 overflow-hidden transition-all duration-500 @(isLogin ? "h-0 opacity-0" : "h-auto opacity-100")">
                    <label class="text-[10px] uppercase tracking-widest font-bold text-primary px-1">PROTOKOL ROLÜ</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-sm">shield_person</span>
                        <InputSelect @bind-Value="registerRoleId" class="w-full bg-surface-container-lowest border-none rounded-md py-3.5 pl-11 pr-4 text-sm text-white/60 appearance-none focus:ring-1 focus:ring-primary focus:bg-surface-container transition-all ease-out-expo">
                            <option value="1">Sistem Yöneticisi</option>
                            <option value="2">Veteriner Hekim</option>
                            <option value="3">Müşteri / Çiftçi</option>
                        </InputSelect>
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-white/30 pointer-events-none">expand_more</span>
                    </div>
                </div>

            <!-- Action Button -->
            <button type="submit" class="group relative w-full bg-primary-container text-on-primary-container font-bold py-4 rounded-md glow-hover transition-all duration-300 ease-out-expo overflow-hidden active:scale-95 disabled:opacity-50" disabled="@isLoading">
                <span class="relative z-10 font-headline uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                    @if(isLoading)
                    {
                        <span class="material-symbols-outlined animate-spin text-sm">hourglass_empty</span>
                        <span>İŞLENİYOR...</span>
                    }
                    else
                    {
                        @(isLogin ? "GİRİŞ YAP" : "HESAP OLUŞTUR")
                        <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    }
                </span>
                <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </button>

            <!-- Auxiliary Actions -->
            <div class="flex justify-between items-center text-xs text-white/40 font-medium pb-2">
                <a href="#" class="hover:text-primary transition-colors">Bilgilerinizi mi unuttunuz?</a>
                <div class="flex gap-3">
                    <span class="material-symbols-outlined text-base">fingerprint</span>
                    <span class="material-symbols-outlined text-base">passkey</span>
                </div>
            </div>
            </div>
        </EditForm>

        <div class="h-px bg-gradient-to-r from-transparent via-outline-variant/20 to-transparent"></div>

        <!-- Footer Context -->
        <div class="flex items-center gap-4 opacity-50">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAnnM6Gz3iZaeeoWVV1_CEc9M5r_L_yVhklR6gRZJbPO3zZkezMIuKk8nBW0cCWCgjMkFe3snDiLWYYCaMyPBqx1z7Kd2ZVvKxmmEFrdHaVTPyvaU2oNhA3N4ggCTKOTUu0lf7tBjDPENLzUjvGwNLtqs0gAmAxNO2wdRGLfXGNSZhZO2OnLnnB7CzPLrg4u8qlZ0nxHot_h_Wuefwa3BJnrRSGoeOfs8Fl2mgQLDpHPVDg6KYZOTmB6pcdQylicaQcl0U177boLPE" class="w-8 h-8 rounded-full grayscale hover:grayscale-0 transition-all cursor-pointer border border-white/10" />
            <div class="text-[10px] leading-tight">
                <p class="text-white">Sadece Yetkili Erişimi</p>
                <p>DP Sistemleri v4.2 ile şifrelenmiştir</p>
            </div>
        </div>
    </div>
</main>

@code {
    [Inject] public IAuthService AuthService { get; set; } = default!;
    [Inject] public NavigationManager Navigation { get; set; } = default!;

    private bool isLogin = true;
    private bool isLoading = false;
    private string? errorMessage = null;

    private LoginDto loginModel = new();
    private object currentModel => loginModel; // Just a dummy bind for EditForm
    private string registerRoleId = "3";

    private void SetMode(bool login)
    {
        isLogin = login;
        errorMessage = null;
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (isLogin)
            {
                var success = await AuthService.LoginAsync(loginModel);
                if (success)
                {
                    Navigation.NavigateTo("/");
                }
                else
                {
                    errorMessage = "Giriş başarısız. Bilgilerinizi kontrol ediniz.";
                }
            }
            else
            {
                var registerDto = new RegisterDto
                {
                    Username = loginModel.Username,
                    Password = loginModel.Password,
                    RoleId = int.Parse(registerRoleId)
                };

                var success = await AuthService.RegisterAsync(registerDto);
                if (success)
                {
                    errorMessage = "Kayıt başarılı. Lütfen giriş yapınız.";
                    SetMode(true);
                }
                else
                {
                    errorMessage = "Kayıt olurken bir hata oluştu. Kullanıcı adı alınmış olabilir.";
                }
            }
        }
        catch (Exception)
        {
            errorMessage = "Sunucu ile iletişim kurulamadı.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
